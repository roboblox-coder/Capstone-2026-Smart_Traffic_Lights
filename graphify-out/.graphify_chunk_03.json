{
  "nodes": [
    {
      "id": "handoff_double_dqn_controller",
      "label": "Double-DQN Controller Integration",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/HANDOFF.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null
    },
    {
      "id": "handoff_set_red_yellow_green_state",
      "label": "Light Control via setRedYellowGreenState",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/HANDOFF.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "SUMO switches TLS into a one-phase override program where setPhase(tls, 6) raises errors if an explicit state string is set. Crucial for env function."
    },
    {
      "id": "handoff_traci_labels",
      "label": "Load-bearing TraCI Labels",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/HANDOFF.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Prevents probe and training sessions from sharing one global TraCI instance."
    },
    {
      "id": "handoff_policy_collapse",
      "label": "Policy Collapse under Short Training",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/HANDOFF.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "At 5 episodes, DQN policy collapses to a single green slot and delta stops incrementing. Needs >= 20 episodes."
    },
    {
      "id": "handoff_state_action_mismatch",
      "label": "State/Action Size Mismatch Fallback",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/HANDOFF.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "If checkpoint was trained on different layout, falls back to actuated control with fallback:state_size_mismatch."
    },
    {
      "id": "planv2_v1_architecture",
      "label": "ATLAS V1 Architecture Baseline",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/PLAN_V2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "12 independent Double-DQN agents using BaseTrafficAI MLP (2x128 ReLU), max_pressure_net reward, and local-only state. Wait/vehicle lower by 7%, throughput tied vs native actuated."
    },
    {
      "id": "planv2_v2_architecture",
      "label": "ATLAS V2 Target Architecture",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/PLAN_V2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Upgrades backbone to FRAP phase-invariant encoder, parameter sharing, CoLight GAT communication, MAPPO centralized critic, pure local pressure reward, and detector-noise domain randomization."
    },
    {
      "id": "planv2_frap_encoder",
      "label": "FRAP Phase-Invariant Encoder",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/PLAN_V2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Phase-symmetry-invariant encoder sharing parameters across all 12 lights, achieving 12x sample reuse to mitigate MAPPO sample inefficiency."
    },
    {
      "id": "planv2_colight_gat",
      "label": "CoLight Graph Attention Network Channel",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/PLAN_V2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Learns attention over upstream, downstream, and cross-street neighbors instead of fixed neighbor summary averages, avoiding local-only ceiling."
    },
    {
      "id": "planv2_mappo",
      "label": "MAPPO Centered Training Decentralized Execution",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/PLAN_V2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Decentralized actors choose actions locally, while a centralized critic uses global state to assign credit, shifting coordination shaping out of the local reward."
    },
    {
      "id": "planv2_pressure_reward",
      "label": "Pure Local Pressure Reward Definition",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/PLAN_V2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Avoids reward-shaping inflation and degradation observed when using naive shared corridor-throughput bonuses."
    },
    {
      "id": "planv2_domain_randomization",
      "label": "Detector-Noise Domain Randomization",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/PLAN_V2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Injects false-negatives (0-15%) and lateral displacement (sigma=0.5m) to bridge the sim-to-real perception gap."
    },
    {
      "id": "planv2_tiered_fallback",
      "label": "Tiered Fallback Signal Control Mechanism",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/PLAN_V2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "5-level fallback logic from healthy RL control down to fixed-time TOD plan. Essential for DOT safety requirements; transitions down are immediate, while upgrading requires N minutes of green-status."
    },
    {
      "id": "planv2_phased_roadmap",
      "label": "Phased Deployment Roadmap",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/PLAN_V2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null
    },
    {
      "id": "planv2_shadow_mode",
      "label": "Counterfactual Shadow Mode Evaluation",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/PLAN_V2.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "RL agent runs in cabinet emitting actions but not actuating. Compares RL action delay vs observed timing via a digital twin to safety-gate live pilot."
    },
    {
      "id": "readme_double_dqn_agent",
      "label": "V1 Double-DQN Agent Definition",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null
    },
    {
      "id": "readme_max_pressure_reward",
      "label": "Max Pressure Reward Mode",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Formulated as -|queue_in - queue_out| / n. Literature standard that keeps DQN loss stable (~0.5) compared to differential reward."
    },
    {
      "id": "readme_combined_reward",
      "label": "Combined Reward Mode (Negative)",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Combined arrived and wait delta (alpha * arrived - beta * delta_wait). Over-weighted throughput and regressed badly; documented negative result."
    },
    {
      "id": "readme_differential_reward",
      "label": "Differential Reward Mode",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Delta wait minus switch penalty. Original reward format, but can suffer from high loss variance (28-130)."
    },
    {
      "id": "readme_anti_starve_reward",
      "label": "Anti-Starve Reward Mode",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Differential reward minus starve penalty times max lane wait."
    },
    {
      "id": "readme_baselines",
      "label": "Signal Control Baselines",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Evaluation includes fixed (round-robin), actuated (greedy max-wait with min-green hysteresis), and native_actuated (SUMO's built-in logic)."
    },
    {
      "id": "report_calibration_status",
      "label": "SUMO Calibration Integrity Status",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/sumo_calibration/report.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Details what data is real (turn-ratio counts for 6 of 12 intersections, OSM junction matches) vs estimated (remaining turn-ratios, saturation flows using HCM defaults, car-following parameters, passenger-only mix, single-hour demand profile, no ped/bike counts, routeSampler-inferred OD matrix)."
    },
    {
      "id": "report_city_engagement_priorities",
      "label": "Bellevue City Engagement Priorities",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/sumo_calibration/report.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Critical long poles needed to remove scare quotes from 'calibrated SUMO': P0 (24h counts, timing plans), P1 (saturation flow surveys, heavy vehicle fractions), P2 (peak counts, ped/bike counts), P3 (OD from ITS)."
    },
