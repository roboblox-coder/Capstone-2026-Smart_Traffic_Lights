    {
      "id": "concept_coordination_shaping",
      "label": "Curriculum Coordination Shaping Rationale",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/train_multi_dqn.py",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Curriculum coordination shaping via shared network-throughput bonus (--net-weight) and downstream-saturation penalty (--coord-penalty) was tested and disabled by default (weight 0.0) as it monotonically degraded real performance vs pure-local waiting-time/pressure policy. The global bonus caused reward inflation without providing learnable credit."
    },
    {
      "id": "concept_anti_thrashing",
      "label": "Anti-Thrashing Action Semantics",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/sumo_env.py",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Enforces minimum green time (min_green) and inserts automatic yellow transitions when switching phases, preventing the RL agent from flickering traffic light signals too rapidly."
    },
    {
      "id": "concept_max_pressure_reward",
      "label": "Max-Pressure Reward Rationale",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/sumo_env.py",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Based on PressLight/MPLight. Minimizing pressure (queue on incoming minus queue on outgoing) stabilizes queue lengths and prevents dumping vehicles into saturated downstream links."
    },
    {
      "id": "concept_anti_starve_reward",
      "label": "Anti-Starve Reward Rationale",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/sumo_env.py",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Adds a penalty for the worst-starved lane to avoid the agent camping indefinitely on the busiest phase slot where flowing lanes dominate wait times."
    },
    {
      "id": "concept_actuated_baseline_corrections",
      "label": "Actuated Baseline Heuristic Corrections",
      "file_type": "rationale",
      "source_file": "SUMO/v2/ai/eval.py",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Corrects legacy mapping of signal indices to unique lanes and uses cumulative waiting time instead of last-step halting count. Halting count drops to near-zero as soon as traffic moves (causing oscillations), whereas waiting time is monotone and serves as a reliable starvation signal."
    }
  ],
